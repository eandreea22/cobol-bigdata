graph TD
    subgraph "Layer 1: Presentation"
        COBOL["COBOL Programs<br/>CUSTOMER-LOOKUP<br/>LOAN-PROCESS<br/>FRAUD-CHECK"]
    end

    subgraph "Layer 2: IPC Bridge"
        IPC["CALL SYSTEM<br/>fixed-width records<br/>timeout 5s<br/>error fallbacks"]
    end

    subgraph "Layer 3: Analytics"
        PY["Python Scripts<br/>customer_360.py<br/>loan_scoring.py<br/>fraud_detect.py<br/>report_aggregator.py"]
    end

    subgraph "Layer 4: Query Engine"
        DUCKDB["DuckDB<br/>in-process SQL<br/>Hive partitioning<br/>row group pruning"]
    end

    subgraph "Layer 5: Data Lake"
        DATA["Apache Parquet<br/>customers.parquet 100K<br/>loans.parquet 500K<br/>transactions/ 10M<br/>date=YYYY-MM-DD partitions<br/>fraud_labels.parquet 50K"]
    end

    COBOL -->|"Input: customer_id<br/>Output: 145B record"| IPC
    IPC -->|"Execute Python<br/>with timeout"| PY
    PY -->|"Query with SQL"| DUCKDB
    DUCKDB -->|"Read Parquet<br/>columns + predicates"| DATA
    DATA -->|"Return results"| DUCKDB
    DUCKDB -->|"Aggregate results"| PY
    PY -->|"Fixed-width output<br/>via ipc_formatter.py"| IPC
    IPC -->|"Parse REDEFINES<br/>FUNCTION NUMVAL"| COBOL
    COBOL -->|"Display/return"| USER["User"]

    style COBOL fill:#4a90e2
    style IPC fill:#f5a623
    style PY fill:#7ed321
    style DUCKDB fill:#50e3c2
    style DATA fill:#b8e986
    style USER fill:#666
